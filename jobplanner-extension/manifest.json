{
  "manifest_version": 3,
  "name": "JobPlanner - Candidatures",
  "version": "1.0.0",
  "description": "Add job offers from any page to JobPlanner",
  "icons": {
    "16": "logo_icon.png",
    "32": "logo_icon.png",
    "48": "logo_icon.png",
    "128": "logo_icon.png"
  },
  "permissions": ["storage", "activeTab", "tabs"],
  "host_permissions": [
    "http://localhost:8000/*",
    "http://localhost:5173/*",
    "http://localhost/*",
    "https://api.ergonis.app/*",
    "https://ergonis.app/*",
    "https://*/*"
  ],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "options_page": "options.html",
  "action": {
    "default_popup": "popup.html",
    "default_title": "Add this page to applications",
    "default_icon": {
      "16": "logo_icon.png",
      "32": "logo_icon.png",
      "48": "logo_icon.png",
      "128": "logo_icon.png"
    }
  }
}
