{
  "manifest_version": 3,
  "name": "JobPlanner - Candidatures",
  "version": "1.0.0",
  "description": "Ajoutez des offres d'emploi depuis n'importe quelle page vers JobPlanner",
  "permissions": ["storage", "activeTab"],
  "host_permissions": ["http://localhost:8000/*", "http://localhost/*", "https://*/*"],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "options_page": "options.html",
  "action": {
    "default_popup": "popup.html",
    "default_title": "Ajouter à JobPlanner"
  }
}
